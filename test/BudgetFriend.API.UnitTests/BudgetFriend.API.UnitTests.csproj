      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\BudgetFriend.API\BudgetFriend.API.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
